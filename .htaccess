# BOS-Score – Apache-Konfiguration

# Zeichenkodierung
AddDefaultCharset UTF-8

# PHP-Einstellungen
<IfModule mod_php.c>
    php_flag display_errors off
    php_value upload_max_filesize 2M
    php_value post_max_size 2M
</IfModule>

# Sicherheitsheader
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Verzeichnislisting deaktivieren
Options -Indexes

# Zugriff auf sensible Dateien blockieren
<FilesMatch "\.(md|example\.php|sh|gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# config.php explizit schützen
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# lib/ Verzeichnis schützen
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^lib/ - [F,L]
</IfModule>

# Zugriff auf exports/ einschränken
<IfModule mod_rewrite.c>
    RewriteRule ^exports/ - [F,L]
</IfModule>
